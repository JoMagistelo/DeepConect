rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.displayName is string && data.displayName.size() <= 50
            && data.onboardingCompleted is bool
            && (!('birthdate' in data) || data.birthdate is string)
            && (!('gender' in data) || data.gender is string)
            && (!('uiStyle' in data) || data.uiStyle in ['holographic', 'blackout', 'red']);
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.onboardingCompleted == true;
      
      allow create: if isOwner(userId) 
          && isValidUser(incoming())
          && !('profileAuthority' in incoming()) // Users can't set their own authority
          && !('reputationWeight' in incoming());

      allow update: if isOwner(userId)
          && (
            // Regular profile update or onboarding completion
            incoming().diff(existing()).affectedKeys().hasOnly([
              'displayName', 'bio', 'photos', 'lastActiveAt', 'onboardingCompleted', 
              'interestTags', 'habits', 'location', 'relationshipGoal', 'datingPsychology', 
              'updatedAt', 'uiStyle', 'birthdate', 'gender', 'zodiacSign', 'id', 'createdAt',
              'profileAuthority'
            ])
          )
          && isValidUser(incoming())
          && (
            !('profileAuthority' in existing()) || 
            incoming().profileAuthority == existing().profileAuthority
          )
          && incoming().reputationWeight == existing().reputationWeight; // Immutable weight
    }

    // --- Swipes ---
    match /swipes/{swipeId} {
      function isValidSwipe(data) {
        return data.swiperId == request.auth.uid
            && data.swipedId is string
            && data.swipedId != request.auth.uid
            && data.direction in ['L', 'R', 'S'];
      }

      allow create, update: if isSignedIn() && isValidSwipe(incoming());
      allow get: if isSignedIn() && (resource == null || resource.data.swipedId == request.auth.uid || resource.data.swiperId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.swiperId == request.auth.uid || resource.data.swipedId == request.auth.uid);
    }

    // --- Matches ---
    match /matches/{matchId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.userIds;
      allow create: if isSignedIn() && request.auth.uid in incoming().userIds && incoming().userIds.size() == 2;
      allow update: if isSignedIn() && request.auth.uid in resource.data.userIds;

      // Messages Sub-collection
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds;
        allow create: if isSignedIn() 
            && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds
            && incoming().senderId == request.auth.uid
            && incoming().content is string
            && incoming().content.size() <= 2000;
        allow update: if isSignedIn() && incoming().read == true && existing().read == false; // Allow marking as read
      }
    }
  }
}
